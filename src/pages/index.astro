---
import BaseHead from '../components/BaseHead.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
import Pricing from '../components/Pricing.jsx'
import { FEATURES } from '../features.js'
import '../styles/global.css'

const APP_URL = 'https://app.ankorax.com'

const title = 'AnkoraX — Invoicing, Accounting & Reports for Small Business'
const description =
  'Run invoices, quotations, expenses, payments, reports, and team roles in one cloud finance workspace. Built for small businesses in Myanmar, Thailand, and GCC.'

const features = [
  ['ti-file-invoice', 'Invoicing & Quotes', 'Create professional invoices and quotations, track status, and follow up faster.'],
  ['ti-wallet', 'Expenses & Cash Flow', 'Record bills, expenses, refunds, and see where your money is going.'],
  ['ti-chart-line', 'Reports & Insights', 'Understand revenue, outstanding payments, clients, and business performance.'],
  ['ti-users', 'Team Roles', 'Invite staff, set permissions, and keep finance work controlled.'],
  ['ti-shield-check', 'Secure Workspace', 'Cloud-based access with structured records, backups, and role control.'],
  ['ti-language', 'Multi-market Ready', 'Useful for Myanmar, Thai, and English-speaking small business teams.'],
]

const faqs = [
  ['What is AnkoraX?', 'AnkoraX is a small business finance workspace for invoices, quotations, expenses, reports, and team controls.'],
  ['Who should use AnkoraX?', 'SMEs, freelancers, agencies, suppliers, and service businesses that want to move away from spreadsheet-heavy finance work.'],
  ['Can I manage invoices and expenses together?', 'Yes. The product is designed to connect invoicing, quotations, expenses, payments, and reports in one place.'],
  ['Is the pricing dynamic?', 'Yes. Pricing is loaded from Firebase when available, with safe fallback plans in the code.'],
]
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'SoftwareApplication',
        name: 'AnkoraX',
        applicationCategory: 'BusinessApplication',
        operatingSystem: 'Web',
        url: 'https://ankorax.com',
        description,
        offers: {
          '@type': 'Offer',
          price: '0',
          priceCurrency: 'USD',
        },
      })}
    />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faqs.map(([q, a]) => ({
          '@type': 'Question',
          name: q,
          acceptedAnswer: {
            '@type': 'Answer',
            text: a,
          },
        })),
      })}
    />
  </head>

  <body>
    <Nav />

    <main>
      <section class="hero" id="top">
        <div class="hero-bg"></div>

        <div class="wrap hero-wrap">
          <div class="eyebrow">Invoicing • Finance • Teams</div>

          <h1>Run your business finances in one place</h1>

          <p class="hero-sub">
            Invoices, quotations, expenses, reports, and your team — all connected in one clean workspace for small businesses.
          </p>

          <div class="hero-actions">
            <a href={`${APP_URL}/signup`} class="btn btn-primary btn-lg">
              Start free <i class="ti ti-arrow-right"></i>
            </a>
            <a href="#pricing" class="btn btn-light btn-lg">See pricing</a>
          </div>

          <div class="hero-checks">
            <span>✓ No card required</span>
            <span>✓ Set up in minutes</span>
            <span>✓ Built for SMEs</span>
          </div>

          <div class="app-shell" aria-label="AnkoraX dashboard preview">
            <aside class="app-sidebar">
              <div class="mini-brand">
                <img src="/ankora_x_logo_2.png" alt="" />
                AnkoraX
              </div>

              {['Overview', 'Invoices', 'Quotes', 'Customers', 'Payments', 'Expenses', 'Reports', 'Team', 'Settings'].map((item, i) => (
                <span class={i === 0 ? 'active' : ''}>
                  <i class={`ti ${['ti-layout-dashboard', 'ti-file-invoice', 'ti-file-description', 'ti-users', 'ti-credit-card', 'ti-receipt', 'ti-chart-bar', 'ti-user-cog', 'ti-settings'][i]}`}></i>
                  {item}
                </span>
              ))}

              <div class="upgrade-box">
                <strong>Upgrade to Pro</strong>
                <small>Unlock advanced reports and team roles.</small>
              </div>
            </aside>

            <section class="app-main">
              <div class="app-top">
                <div>
                  <strong>Overview</strong>
                  <small>Welcome back, Alex 👋</small>
                </div>
                <button>May 1 — May 31</button>
              </div>

              <div class="metric-grid">
                <div class="metric-card">
                  <small>Total Revenue</small>
                  <strong>2,450,000</strong>
                  <span class="up">↑ 12.5% this month</span>
                </div>

                <div class="metric-card">
                  <small>Outstanding</small>
                  <strong>850,000</strong>
                  <span class="warn">↑ 8.2% pending</span>
                </div>

                <div class="metric-card">
                  <small>Total Clients</small>
                  <strong>142</strong>
                  <span class="up">↑ 6 new</span>
                </div>
              </div>

              <div class="dash-grid">
                <div class="chart-card">
                  <div class="card-title">Revenue Overview</div>
                  <svg viewBox="0 0 600 190" role="img">
                    <path d="M0 145 C70 120 95 120 130 110 S210 145 250 110 S310 95 350 90 S420 120 465 82 S540 70 600 40" fill="none" stroke="url(#g)" stroke-width="5" />
                    <path d="M0 145 C70 120 95 120 130 110 S210 145 250 110 S310 95 350 90 S420 120 465 82 S540 70 600 40 L600 190 L0 190 Z" fill="url(#a)" />
                    <defs>
                      <linearGradient id="g" x1="0" x2="1">
                        <stop stop-color="#8b5cf6" />
                        <stop offset="1" stop-color="#3b82f6" />
                      </linearGradient>
                      <linearGradient id="a" y1="0" y2="1">
                        <stop stop-color="#8b5cf633" />
                        <stop offset="1" stop-color="#8b5cf600" />
                      </linearGradient>
                    </defs>
                  </svg>
                </div>

                <div class="invoice-card">
                  <div class="card-title">Invoices</div>
                  <div class="donut">
                    <span>125<small>Total</small></span>
                  </div>
                  <p><b class="dot paid"></b>Paid 80</p>
                  <p><b class="dot pending"></b>Pending 30</p>
                  <p><b class="dot overdue"></b>Overdue 15</p>
                </div>
              </div>
            </section>
          </div>

          <div class="trust-row">
            <span>Trusted by growing businesses</span>
            <b>Bright Solutions</b>
            <b>Design Studio</b>
            <b>Tech Innovators</b>
            <b>Growth Labs</b>
          </div>
        </div>
      </section>

      <section class="section" id="features">
        <div class="wrap">
          <div class="section-head">
            <span class="eyebrow">Features</span>
            <h2>Everything the back office needs</h2>
            <p>One connected system for invoices, books, reports, and business decisions.</p>
          </div>

          <div class="feature-grid">
            {features.map(([icon, title, body], i) => (
              <a class="feature-card" href={`/features/${FEATURES[i]?.slug || 'invoices-quotations'}`}>
                <i class={`ti ${icon}`}></i>
                <h3>{title}</h3>
                <p>{body}</p>
                <span>Learn more <i class="ti ti-arrow-right"></i></span>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section class="section process" id="process">
        <div class="wrap">
          <div class="section-head">
            <span class="eyebrow">Process</span>
            <h2>From blank page to balanced books</h2>
            <p>Simple steps. Powerful results.</p>
          </div>

          <div class="process-grid">
            <div>
              <span>01</span>
              <i class="ti ti-file-plus"></i>
              <h3>Create</h3>
              <p>Build an invoice or quote with your branding in a few clicks.</p>
            </div>

            <div>
              <span>02</span>
              <i class="ti ti-send"></i>
              <h3>Send & get paid</h3>
              <p>Deliver to clients, track payments, and follow up automatically.</p>
            </div>

            <div>
              <span>03</span>
              <i class="ti ti-chart-histogram"></i>
              <h3>See the whole picture</h3>
              <p>Track performance, outstanding amounts, expenses, and reports.</p>
            </div>
          </div>
        </div>
      </section>

      <section class="section" id="pricing">
        <div class="wrap">
          <div class="section-head">
            <span class="eyebrow">Pricing</span>
            <h2>Plans that grow with your business</h2>
            <p>Start free. Upgrade when you are ready. No hidden fees.</p>
          </div>
          <Pricing client:visible />
        </div>
      </section>

      <section class="section testimonials">
        <div class="wrap">
          <div class="section-head">
            <span class="eyebrow">Trusted by businesses</span>
            <h2>Loved by businesses worldwide</h2>
            <p>Clear finance tools for busy owners and teams.</p>
          </div>

          <div class="testimonial-grid">
            <article>
              ★★★★★
              <p>“AnkoraX transformed how we manage invoices and finances. It is fast, intuitive, and reliable.”</p>
              <strong>Sarah Mitchell</strong>
              <small>CFO, Bright Ideas Co.</small>
            </article>

            <article>
              ★★★★★
              <p>“The real-time insights and workflow save us hours every week.”</p>
              <strong>James Carter</strong>
              <small>Founder, Carter & Co.</small>
            </article>

            <article>
              ★★★★★
              <p>“Excellent platform with everything our back office needs in one place.”</p>
              <strong>Priya Shah</strong>
              <small>Finance Manager</small>
            </article>
          </div>
        </div>
      </section>

      <section class="section faq" id="faq">
        <div class="wrap">
          <div class="section-head">
            <span class="eyebrow">FAQ</span>
            <h2>Frequently asked questions</h2>
            <p>Answers for small business owners comparing AnkoraX.</p>
          </div>

          <div class="faq-grid">
            {faqs.map(([q, a], i) => (
              <details open={i === 0}>
                <summary>{q}</summary>
                <p>{a}</p>
              </details>
            ))}
          </div>
        </div>
      </section>

      <section class="section security" id="security">
        <div class="wrap">
          <div class="section-head">
            <span class="eyebrow">Security & Trust</span>
            <h2>Your data is safe with us</h2>
            <p>Protect your finance records with secure access and structured backups.</p>
          </div>

          <div class="security-grid">
            <div>
              <i class="ti ti-lock"></i>
              <h3>Bank-level encryption</h3>
              <p>Encrypted data in transit and at rest.</p>
            </div>

            <div>
              <i class="ti ti-cloud-lock"></i>
              <h3>Secure infrastructure</h3>
              <p>Cloud-hosted infrastructure for reliable access.</p>
            </div>

            <div>
              <i class="ti ti-database"></i>
              <h3>Regular backups</h3>
              <p>Automatic backups keep your data recoverable.</p>
            </div>

            <div>
              <i class="ti ti-shield-check"></i>
              <h3>Compliance first</h3>
              <p>Built with security and privacy in mind.</p>
            </div>
          </div>
        </div>
      </section>

      <section class="final-cta">
        <div class="wrap">
          <div class="cta-panel">
            <h2>Ready to organize your business finance?</h2>
            <p>Start with invoices today. Add expenses, reports, and team roles as you grow.</p>
            <a href={`${APP_URL}/signup`} class="btn btn-white btn-lg">Start free</a>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>
