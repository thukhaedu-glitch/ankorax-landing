---
const APP_URL = 'https://app.ankorax.com'
const TEAM_URL = 'https://team.ankorax.com'
---
<footer class="footer">
  <div class="wrap footer-grid">
    <div class="footer-brand">
      <a href="/" class="brand">
        <img src="/ankora_x_logo_2.png" alt="AnkoraX" width="34" height="34" />
        <span>AnkoraX</span>
      </a>
      <p>Modern invoicing, quotations, expenses, reports, and team controls for small businesses in Myanmar, Thailand, and GCC.</p>
      <div class="footer-badges">
        <span>Secure data</span>
        <span>SME ready</span>
        <span>Cloud based</span>
      </div>
    </div>

    <div class="footer-col">
      <h3>Product</h3>
      <a href="/#features">Features</a>
      <a href="/#pricing">Pricing</a>
      <a href={`${APP_URL}/signup`}>Start free</a>
      <a href={`${APP_URL}/login`}>Log in</a>
    </div>

    <div class="footer-col">
      <h3>Solutions</h3>
      <a href="/features/invoicing">Invoicing</a>
      <a href="/features/quotation">Quotations</a>
      <a href="/features/team-roles">Team roles</a>
      <a href={TEAM_URL}>Team workspace</a>
    </div>

    <div class="footer-col">
      <h3>Resources</h3>
      <a href="/blog">Blog</a>
      <a href="/#faq">FAQ</a>
      <a href="/#security">Security</a>
      <a href="mailto:hello@ankorax.com">Contact</a>
    </div>
  </div>

  <div class="wrap footer-bottom">
    <span>© 2026 AnkoraX. All rights reserved.</span>
    <span>Built for growing businesses.</span>
  </div>
</footer>
